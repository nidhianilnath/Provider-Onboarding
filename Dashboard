function buildTable(providers, team) {
  const extraCols = team === 'all' ? TEAM_EXTRA_COLS.talent : (TEAM_EXTRA_COLS[team] || []);
  const cols = [...BASE_COLS, ...extraCols];

  if (providers.length === 0) {
    return `<div class="no-providers">No providers match the current filters.</div>`;
  }

  const thead = cols.map(c => `<th>${c.label} <span class="sort-icon">↕</span></th>`).join('');
  const tbody = providers.map(p => {
    const cells = cols.map(c => `<td>${c.render(p)}</td>`).join('');
    return `<tr>${cells}</tr>`;
  }).join('');

  return `<div class="table-scroll"><table>
    <thead><tr>${thead}</tr></thead>
    <tbody>${tbody}</tbody>
  </table></div>`;
}

// ─── RENDER ─────────────────────────────────────────────────────────────────
function render() {
  const cohorts = getFilteredCohorts();
  const providers = getFilteredProviders();
  const team = currentTeam;
  const el = document.getElementById('mainContent');

  let html = '';

  if (currentView === 'cohort') {
    html += `<div class="section-header"><span class="section-title">Cohort Summary — ${teamLabel(team)}</span><span style="font-size:11px;color:var(--text-muted)">${cohorts.length} cohort${cohorts.length !== 1 ? 's' : ''}</span></div>`;
    if (cohorts.length === 0) {
      html += `<div class="empty-state">No cohorts match the current filters.</div>`;
    } else {
      html += `<div class="cohort-grid">`;
      cohorts.forEach(c => { html += buildCohortCard(c, team); });
      html += `</div>`;
    }
  } else {
    html += `<div class="section-header" style="margin-bottom:12px"><span class="section-title">Provider Detail — ${teamLabel(team)}</span><span style="font-size:11px;color:var(--text-muted)">${providers.length} provider${providers.length !== 1 ? 's' : ''}</span></div>`;
    html += `<div class="table-section"><div class="table-wrapper">${buildTable(providers, team)}</div></div>`;
  }

  el.innerHTML = html;
}

function teamLabel(t) {
  const map = {
    all: 'All Teams', talent: 'Talent Acquisition', licensing: 'Licensing',
    informatics: 'Clinical Informatics', coreops: 'Core Operations',
    it: 'IT', hr: 'HR', marketing: 'Digital Marketing', credentialing: 'Credentialing'
  };
  return map[t] || t;
}

function switchTeam(val) {
  currentTeam = val;
  document.querySelectorAll('.team-tab').forEach(t => {
    t.classList.toggle('active', t.dataset.team === val);
  });
  render();
}

function switchTeamTab(val) {
  currentTeam = val;
  document.getElementById('filterTeam').value = val;
  document.querySelectorAll('.team-tab').forEach(t => {
    t.classList.toggle('active', t.dataset.team === val);
  });
  render();
}

function setView(v, btn) {
  currentView = v;
  document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  render();
}

function applyFilters() {
  filterDate = document.getElementById('filterStartDate').value;
  filterType = document.getElementById('filterProviderType').value;
  render();
}

// Init
document.getElementById('lastUpdated').textContent = 'Updated ' + new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
render();
</script>
