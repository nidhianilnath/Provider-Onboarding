    { label: 'NP Max', render: p => p.npMax },
    { label: 'ADHD', render: p => boolPill(p.adhdEnabled, 'On', 'Off') },
    { label: 'CS Disabled', render: p => p.csDisabled ? `<span class="pill pill-red">Yes</span>` : `<span class="pill pill-green">No</span>` },
  ],
  credentialing: [
    { label: 'Committee Approval Date', render: p => fmt(p.credDate) },
  ],
