    { label: 'In Prog. CSRs', render: p => p.inProgressCsrs },
    { label: 'NY/TX Lic.', render: p => p.nyOrTx ? `<span class="pill pill-purple">${p.nyOrTx}</span>` : '—' },
    { label: 'Cred. Date', render: p => fmt(p.credDate) },
  ],
  informatics: [
    { label: 'Primary Market', render: p => p.primaryMarket },
