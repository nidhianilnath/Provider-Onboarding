<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Provider Onboarding Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #f5f4f0;
    --surface: #ffffff;
    --surface2: #f0efe9;
    --border: #e2e0d8;
    --border-strong: #c8c6bc;
    --text: #1a1917;
    --text-secondary: #6b6a64;
    --text-muted: #9c9b95;
    --accent: #1a3a2a;
    --accent-light: #e8f0eb;
    --accent-mid: #4a7c5f;
    --green: #2d6a4f;
    --green-bg: #d8f3dc;
    --green-text: #1b4332;
    --red: #c1121f;
    --red-bg: #ffe5e5;
    --red-text: #7d0000;
    --amber: #b45309;
    --amber-bg: #fef3c7;
    --amber-text: #78350f;
    --blue: #1e40af;
    --blue-bg: #dbeafe;
    --blue-text: #1e3a8a;
    --purple: #6d28d9;
    --purple-bg: #ede9fe;
    --purple-text: #4c1d95;
    --radius: 8px;
    --radius-lg: 12px;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 14px;
    line-height: 1.5;
    min-height: 100vh;
  }

  /* HEADER */
  .header {
    background: var(--accent);
    color: white;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .header-title {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .header-sub {
    font-size: 12px;
    opacity: 0.6;
    margin-top: 1px;
  }
  .header-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .last-updated {
    font-size: 11px;
    opacity: 0.5;
    font-family: 'DM Mono', monospace;
  }

  /* FILTERS */
  .filters-bar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 12px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .filter-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
  .filter-group {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  select, input[type="date"] {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    padding: 6px 10px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    outline: none;
    transition: border-color 0.15s;
  }
  select:hover, input[type="date"]:hover { border-color: var(--border-strong); }
  select:focus, input[type="date"]:focus { border-color: var(--accent-mid); box-shadow: 0 0 0 2px rgba(74,124,95,0.15); }

  /* TEAM TABS */
  .team-tabs {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    display: flex;
    gap: 0;
    overflow-x: auto;
  }
  .team-tab {
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: all 0.15s;
    user-select: none;
  }
  .team-tab:hover { color: var(--text); background: var(--surface2); }
  .team-tab.active { color: var(--accent); border-bottom-color: var(--accent-mid); }

  /* MAIN CONTENT */
  .main { padding: 20px 24px; max-width: 1400px; }

  /* COHORT SUMMARY */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .section-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .cohort-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 12px;
    margin-bottom: 28px;
  }
  .cohort-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .cohort-card-header {
    background: var(--accent);
    color: white;
    padding: 12px 16px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .cohort-date {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .cohort-category {
    font-size: 11px;
    opacity: 0.65;
    margin-top: 2px;
  }
  .countdown-badge {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    background: rgba(255,255,255,0.15);
    padding: 3px 8px;
    border-radius: 20px;
    white-space: nowrap;
  }
  .cohort-card-body { padding: 12px 16px; }
  .cohort-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
    gap: 8px;
    margin-top: 8px;
  }
  .stat-box {
    background: var(--surface2);
    border-radius: var(--radius);
    padding: 8px 10px;
    text-align: center;
  }
  .stat-value {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.02em;
    font-family: 'DM Mono', monospace;
  }
  .stat-label {
    font-size: 10px;
    color: var(--text-muted);
    margin-top: 2px;
    line-height: 1.3;
  }
  .go-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 20px;
  }
  .go-badge.go { background: var(--green-bg); color: var(--green-text); }
  .go-badge.nogo { background: var(--red-bg); color: var(--red-text); }
  .go-badge.pending { background: var(--amber-bg); color: var(--amber-text); }

  /* PROVIDER TABLE */
  .table-section { margin-bottom: 32px; }
  .table-wrapper {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .table-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
  }
  .table-count {
    font-size: 12px;
    color: var(--text-muted);
    font-family: 'DM Mono', monospace;
  }
  .search-input {
    padding: 5px 10px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 12px;
    width: 200px;
  }
  .table-scroll { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12.5px;
    min-width: 600px;
  }
  thead th {
    background: var(--surface2);
    padding: 8px 12px;
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    user-select: none;
    position: sticky;
    top: 0;
  }
  thead th:hover { background: var(--border); }
  thead th .sort-icon { opacity: 0.4; margin-left: 3px; }
  thead th.sorted .sort-icon { opacity: 1; color: var(--accent-mid); }
  tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: var(--surface2); }
  tbody td { padding: 8px 12px; color: var(--text); vertical-align: middle; }
  .provider-name { font-weight: 500; }
  .npi-code { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text-muted); }
  .pill {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 20px;
  }
  .pill-green { background: var(--green-bg); color: var(--green-text); }
  .pill-red { background: var(--red-bg); color: var(--red-text); }
  .pill-amber { background: var(--amber-bg); color: var(--amber-text); }
  .pill-blue { background: var(--blue-bg); color: var(--blue-text); }
  .pill-gray { background: var(--surface2); color: var(--text-secondary); }
  .pill-purple { background: var(--purple-bg); color: var(--purple-text); }
  .empty-state {
    text-align: center;
    padding: 48px 24px;
    color: var(--text-muted);
    font-size: 13px;
  }
  .divider {
    height: 1px;
    background: var(--border);
    margin: 24px 0;
  }

  /* TEAM PANEL */
  .team-panel { display: none; }
  .team-panel.active { display: block; }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .header { padding: 12px 16px; }
    .filters-bar { padding: 10px 16px; }
    .main { padding: 16px; }
    .cohort-grid { grid-template-columns: 1fr; }
  }

  .view-toggle {
    display: flex;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .view-btn {
    padding: 5px 12px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    background: none;
    border: none;
    color: var(--text-secondary);
    transition: all 0.15s;
  }
  .view-btn.active { background: var(--accent); color: white; }

  .no-providers {
    padding: 32px;
    text-align: center;
    color: var(--text-muted);
    font-size: 13px;
  }
</style>
</head>
<body>

<header class="header">
  <div>
    <div class="header-title">Provider Onboarding Dashboard</div>
    <div class="header-sub">Cohort tracking &amp; team readiness</div>
  </div>
  <div class="header-right">
    <span class="last-updated" id="lastUpdated"></span>
  </div>
</header>

<div class="filters-bar">
  <span class="filter-label">Filters</span>
  <div class="filter-group">
    <label class="filter-label" for="filterStartDate">Start Date</label>
    <input type="date" id="filterStartDate" onchange="applyFilters()">
  </div>
  <div class="filter-group">
    <label class="filter-label" for="filterProviderType">Provider Type</label>
    <select id="filterProviderType" onchange="applyFilters()">
      <option value="">All Types</option>
      <option>MD</option>
      <option>DO</option>
      <option>NP</option>
      <option>PA</option>
      <option>LCSW</option>
      <option>Psychiatrist</option>
    </select>
  </div>
  <div class="filter-group">
    <label class="filter-label" for="filterTeam">Team</label>
    <select id="filterTeam" onchange="switchTeam(this.value)">
      <option value="all">All Teams</option>
      <option value="talent">Talent Acquisition</option>
      <option value="licensing">Licensing</option>
      <option value="informatics">Clinical Informatics</option>
      <option value="coreops">Core Operations</option>
      <option value="it">IT</option>
      <option value="hr">HR</option>
      <option value="marketing">Digital Marketing</option>
      <option value="credentialing">Credentialing</option>
    </select>
  </div>
  <div style="margin-left:auto;" class="view-toggle">
    <button class="view-btn active" onclick="setView('cohort',this)">Cohort Summary</button>
    <button class="view-btn" onclick="setView('detail',this)">Detail View</button>
  </div>
</div>

<div class="team-tabs" id="teamTabs">
  <div class="team-tab active" data-team="all" onclick="switchTeamTab('all')">All Teams</div>
  <div class="team-tab" data-team="talent" onclick="switchTeamTab('talent')">Talent Acquisition</div>
  <div class="team-tab" data-team="licensing" onclick="switchTeamTab('licensing')">Licensing</div>
  <div class="team-tab" data-team="informatics" onclick="switchTeamTab('informatics')">Clinical Informatics</div>
  <div class="team-tab" data-team="coreops" onclick="switchTeamTab('coreops')">Core Operations</div>
  <div class="team-tab" data-team="it" onclick="switchTeamTab('it')">IT</div>
  <div class="team-tab" data-team="hr" onclick="switchTeamTab('hr')">HR</div>
  <div class="team-tab" data-team="marketing" onclick="switchTeamTab('marketing')">Digital Marketing</div>
  <div class="team-tab" data-team="credentialing" onclick="switchTeamTab('credentialing')">Credentialing</div>
</div>

<div class="main" id="mainContent"></div>

<script>
// ─── SAMPLE DATA ───────────────────────────────────────────────────────────
