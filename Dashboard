    fte: 1.0, signDate: '2025-05-20', startDate: '2025-09-08', withdrawDate: '',
    completeLicenses: 1, incompleteLicenses: 4, activeLicenses: 1, openMarkets: ['CA'],
    openMarketsCount: 1, licensesAvailable: 1, inProgressLicenses: 4,
    activeDeas: 0, inProgressDeas: 1, activeCsrs: 0, inProgressCsrs: 1,
    nyOrTx: '', credDate: 'TBD',
    primaryMarket: 'California', schedCreated: false, laptopSetup: false,
    w1Patients: 0, w2Patients: 0, w3Patients: 0, w4Patients: 0, totalPatients: 0,
    adpSetup: false,
    synapseProfile: 'Not Started', synapseLoc: 'CA-Los Angeles', matchingEnabled: false,
    newPatientEnabled: false, npMax: 22, adhdEnabled: true, csDisabled: false
  }
];

// ─── STATE ──────────────────────────────────────────────────────────────────
let currentTeam = 'all';
let currentView = 'cohort';
let filterDate = '';
let filterType = '';

// ─── UTILS ──────────────────────────────────────────────────────────────────
function countdown(dateStr) {
  if (!dateStr || dateStr === 'TBD') return 'TBD';
  const diff = Math.ceil((new Date(dateStr) - new Date()) / 86400000);
  if (diff < 0) return `${Math.abs(diff)}d ago`;
  if (diff === 0) return 'Today';
  return `${diff}d`;
}

function fmt(dateStr) {
  if (!dateStr) return '—';
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function boolPill(val, trueLabel, falseLabel) {
  if (val === true || val === 'Complete' || val === 'Active') {
    return `<span class="pill pill-green">${trueLabel || '✓'}</span>`;
  }
  if (val === 'In Progress' || val === 'Pending') {
    return `<span class="pill pill-amber">${val}</span>`;
  }
  if (val === false || val === 'Not Started') {
    return `<span class="pill pill-red">${falseLabel || '—'}</span>`;
  }
  return `<span class="pill pill-gray">${val}</span>`;
}

function getFilteredProviders() {
  return PROVIDERS.filter(p => {
    if (filterDate && p.startDate !== filterDate) return false;
    if (filterType && p.type !== filterType) return false;
    return true;
  });
}

function getFilteredCohorts() {
  return COHORTS.filter(c => {
    if (filterDate && c.startDate !== filterDate) return false;
    return true;
  });
}

// ─── COHORT CARD BUILDER ────────────────────────────────────────────────────
function buildCohortCard(c, team) {
  const cd = countdown(c.startDate);
  const cdClass = cd.includes('ago') ? 'style="color:#c1121f"' : '';
  const goLabel = c.goNogo === 'go' ? 'Go ✓' : c.goNogo === 'nogo' ? 'No-Go ✗' : 'Pending';
  const goClass = c.goNogo;

  let stats = `<div class="stat-box"><div class="stat-value go-badge ${goClass}">${goLabel}</div><div class="stat-label">Go / No-Go</div></div>`;

  const statBlock = (val, label) =>
    `<div class="stat-box"><div class="stat-value">${val}</div><div class="stat-label">${label}</div></div>`;

  if (team === 'all' || team === 'talent') {
    stats += statBlock(c.openMarkets, 'Open Markets') + statBlock(c.completeMarkets, 'Complete Markets') + statBlock(c.incompleteMarkets, 'Incomplete');
  } else if (team === 'licensing') {
    stats += statBlock(c.openMarkets, 'Open Markets') + statBlock(c.completeMarkets, 'Complete') + statBlock(c.incompleteMarkets, 'Incomplete') + statBlock(c.credDate !== 'TBD' ? fmt(c.credDate) : 'TBD', 'Cred. Date');
  } else if (team === 'informatics') {
    stats += statBlock(c.schedBlocks, 'Schedule & Blocks');
  } else if (team === 'coreops') {
    stats += statBlock(c.patientSched, 'Wk 1 Patients');
  } else if (team === 'it') {
    stats += statBlock(c.techSetup, 'Tech Setup');
  } else if (team === 'hr') {
    stats += statBlock(c.adpSetup, 'ADP Setup');
  } else if (team === 'marketing') {
    stats += statBlock(c.profilesActivated, 'Profiles Activated');
  } else if (team === 'credentialing') {
    stats += statBlock(c.credDate !== 'TBD' ? fmt(c.credDate) : 'TBD', 'Credentialing Date');
  }

  return `<div class="cohort-card">
    <div class="cohort-card-header">
      <div>
        <div class="cohort-date">${fmt(c.startDate)}</div>
        <div class="cohort-category">${c.category}</div>
      </div>
      <div class="countdown-badge" ${cdClass}>${cd}</div>
    </div>
    <div class="cohort-card-body">
      <div class="cohort-stats">${stats}</div>
    </div>
  </div>`;
}

// ─── TABLE COLUMN CONFIGS ───────────────────────────────────────────────────
const BASE_COLS = [
  { label: 'Name', render: p => `<span class="provider-name">${p.name}</span>` },
  { label: 'Type', render: p => `<span class="pill pill-blue">${p.type}</span>` },
  { label: 'NPI', render: p => `<span class="npi-code">${p.npi}</span>` },
  { label: 'Chief', render: p => p.chief },
  { label: 'FTE', render: p => p.fte },
  { label: 'Sign Date', render: p => fmt(p.signDate) },
  { label: 'Start Date', render: p => fmt(p.startDate) },
  { label: 'Withdrawal', render: p => p.withdrawDate ? fmt(p.withdrawDate) : '—' },
];

